{
  "name": "alvaro.cuesta.dev",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Álvaro Cuesta's personal website.",
  "main": "index.js",
  "scripts": {
    "build": "cross-env NODE_ENV=production tsx --import ./src/mdx/mdxNodeLoaderRegister.mjs ./bin/build.ts",
    "build:serve": "serve ./dist",
    "dev": "cross-env NODE_ENV=development tsx watch --include ./src/**/*.ts --include ./src/**/*.tsx --include ./src/**/*.mdx --include ./config.ts --include ../xenon-ssg/src --include ../xenon-ssg-express/src --import ./src/mdx/mdxNodeLoaderRegister.mjs ./bin/dev.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:tsc": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alvaro-cuesta/alvaro.cuesta.dev.git"
  },
  "author": "Álvaro Cuesta <alvaro-cuesta@GitHub>",
  "bugs": {
    "url": "https://github.com/alvaro-cuesta/alvaro.cuesta.dev/issues"
  },
  "homepage": "https://github.com/alvaro-cuesta/alvaro.cuesta.dev#readme",
  "dependencies": {
    "@mdx-js/node-loader": "^3.0.1",
    "@picocss/pico": "^2.0.6",
    "@stefanprobst/rehype-extract-toc": "^2.2.0",
    "@wooorm/starry-night": "^3.4.0",
    "classnames": "^2.5.1",
    "fontawesome-free": "^1.0.4",
    "html-to-text": "^9.0.5",
    "path-to-regexp": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recma-mdx-is-mdx-component": "^1.1.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.0",
    "rehype-shift-heading": "^2.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-starry-night": "^2.1.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "temporal-polyfill": "^0.2.5",
    "tldts": "^7.0.28",
    "xenon-ssg-express": "../xenon-ssg-express",
    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "@types/html-to-text": "^9.0.4",
    "@types/jest": "^29.5.12",
    "@types/mdx": "^2.0.13",
    "@types/mock-fs": "^4.13.4",
    "@types/react": "^18.3.3",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mock-fs": "^5.5.0",
    "serve": "^14.2.4",
    "ts-jest": "^29.2.3",
    "tsx": "^4.21.0",
    "vitest": "^3.2.4"
  }
}
